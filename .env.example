# Copie ce fichier en .env.local pour activer la synchronisation cloud.
# Laisse les variables vides pour rester en mode LocalStorage 100% offline.

# Project URL du dashboard Supabase → Settings → API
VITE_SUPABASE_URL=

# anon / public key du dashboard Supabase → Settings → API
VITE_SUPABASE_ANON_KEY=
