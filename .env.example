# Copie ce fichier en .env (ou .env.local) pour activer les intégrations.

# ─── Supabase (sync cloud, optionnel) ──────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Coach IA (LLM compatible OpenAI, ex: Groupe GENES / Llama 3.3) ─
# ATTENTION : toute variable VITE_* est inlinée dans le bundle JS et
# donc lisible côté navigateur. À usage personnel/local uniquement —
# en prod, passe par un proxy serveur qui détient la vraie clé.
VITE_LLM_API_KEY=
VITE_LLM_BASE_URL=https://llm.lab.groupe-genes.fr/openai
VITE_LLM_MODEL=llama3.3:latest
